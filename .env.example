ROLE_SYNC_INTERVAL_MS=300000
# Cache roster sheet reads to avoid Google Sheets per-minute read quota (default: 90 seconds)
# ROSTER_CACHE_TTL_MS=90000
# Optional: pin audit log channel across redeploys (otherwise use /setupauditlog)
